{
  "easycom": {
    "^u-(.*)": "uview-plus/components/u-$1/u-$1.vue",
    "^up-(.*)": "uview-plus/components/u-$1/u-$1.vue"
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "神秘星空解梦",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/loading/loading",
      "style": {
        "navigationBarTitleText": "星点汇聚",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationStyle": "custom",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/result/result",
      "style": {
        "navigationBarTitleText": "解梦结果",
        "navigationBarBackgroundColor": "#1A1033",
        "enableShareAppMessage": true,
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "梦境历史",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/detail/detail",
      "style": {
        "navigationBarTitleText": "梦境详情",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/poster/poster",
      "style": {
        "navigationBarTitleText": "分享海报",
        "navigationBarBackgroundColor": "#1A1033",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "神秘星空解梦",
    "navigationBarBackgroundColor": "#1A1033",
    "backgroundColor": "#0A0820"
  }
}
