{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@dcloudio/types"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["vite.config.ts", "src/**/*.ts", "src/**/*.vue", "src/pages.json", "src/manifest.json"]
}
