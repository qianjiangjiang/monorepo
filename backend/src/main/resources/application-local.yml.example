spring:
  datasource:
    url: jdbc:mysql://localhost:3306/dream?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: dream
    password: change-me
    driver-class-name: com.mysql.cj.jdbc.Driver
  data:
    redis:
      host: localhost
      port: 6379
      password:

dream:
  jwt:
    secret: replace-with-a-32-byte-jwt-secret
  wx:
    app-id: your-wechat-miniapp-app-id
    app-secret: your-wechat-miniapp-app-secret
    mock-enabled: true
    content-safety-enabled: true
  interpret:
    daily-free-limit: 5
    cache-ttl-seconds: 86400
  ai:
    encryption-key: replace-with-a-32-byte-ai-encryption-key
    deepseek:
      base-url: https://api.deepseek.com
      api-key: ${DEEPSEEK_API_KEY:}
